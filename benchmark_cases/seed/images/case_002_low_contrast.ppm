۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰