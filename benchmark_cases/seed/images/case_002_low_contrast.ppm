۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰