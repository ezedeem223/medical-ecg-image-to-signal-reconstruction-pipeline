۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰