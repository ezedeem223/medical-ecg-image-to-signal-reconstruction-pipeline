۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶