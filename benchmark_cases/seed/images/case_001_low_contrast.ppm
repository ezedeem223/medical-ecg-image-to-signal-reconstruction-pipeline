۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰((((((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰(((۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰۶۰۰